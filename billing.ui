     <string notr="true">#camerawidget {
    background-color: rgb(255, 255, 255);
}

#scanButton {
    border: 2px solid rgb(45, 134, 134); /* Border color */
    background-color: rgb(85, 255, 255); /* Button background color */
    border-radius: 10px; /* Round the corners */
    padding: 10px; /* Adjust padding for better look */
	outline: none;
}

#scanButton:hover {
    background-color: rgb(65, 235, 235); /* Slightly darker on hover */
}

#scanButton:pressed {
    background-color: rgb(45, 205, 205); /* Even darker when pressed */
}
</string>
